---
layout: base.njk
---
{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://enricopiovesan.com/writing/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enricopiovesan.com/" },
        { "@type": "ListItem", "position": 2, "name": "Writing", "item": "https://enricopiovesan.com/writing/" }
      ]
    },
    {
      "@type": "ItemList",
      "name": "Writing Series by Enrico Piovesan",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "item": {
            "@type": "Periodical",
            "name": "Mastering Software Architecture for the AI Era",
            "url": "https://medium.com/software-architecture-in-the-age-of-ai",
            "author": { "@id": "https://enricopiovesan.com/#person" },
            "about": ["Software Architecture", "AI-native Systems", "C-DAD"],
            "inLanguage": "en"
          }
        },
        {
          "@type": "ListItem",
          "position": 2,
          "item": {
            "@type": "Periodical",
            "name": "The Rise of Device-Independent Architecture",
            "url": "https://medium.com/the-rise-of-device-independent-architecture",
            "author": { "@id": "https://enricopiovesan.com/#person" },
            "about": ["WebAssembly", "UMA", "Device-Independent Architecture"],
            "inLanguage": "en"
          }
        }
      ]
    }
  ]
}
</script>
{% endblock %}

{% set nav = sectionNavs[sectionGroup] %}
<div class="section-shell">
  <aside class="section-nav-aside" aria-label="{{ nav.label }} navigation">
    {% if nav.url %}<a class="section-nav-label" href="{{ nav.url }}">{{ nav.label }}</a>{% else %}<span class="section-nav-label">{{ nav.label }}</span>{% endif %}
    {% if nav.links %}
    <ul class="section-nav-links">
      {% for link in nav.links %}
      <li><a href="{{ link.href }}"{% if page.url == link.href %} class="active" aria-current="page"{% endif %}>{{ link.label }}</a></li>
      {% endfor %}
    </ul>
    {% endif %}
  </aside>

  <main class="section-main">
    <nav class="section-breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        {% if breadcrumb %}
          {% for crumb in breadcrumb %}
            {% if loop.last %}<li><span aria-current="page">{{ crumb.label }}</span></li>
            {% else %}<li><a href="{{ crumb.href }}">{{ crumb.label }}</a></li>
            {% endif %}
          {% endfor %}
        {% else %}
        <li><span aria-current="page">{{ title }}</span></li>
        {% endif %}
      </ol>
    </nav>

    <div class="section-body">

<section class="hero">
  <p class="hero-label">Medium</p>
  <h1>Writing</h1>
  {% if intro is string %}
  <p class="hero-bio">{{ intro }}</p>
  {% else %}
  {% for para in intro %}
  <p class="hero-bio" style="margin-top:{% if loop.first %}0{% else %}1rem{% endif %};">{{ para }}</p>
  {% endfor %}
  {% endif %}
</section>

{% for pub in series %}
<div class="writing-series">
  <div class="series-header">
    <h2 class="series-name"><a href="{{ pub.url }}" target="_blank" rel="noopener">{{ pub.name }}</a></h2>
  </div>
  <p class="series-cadence">{{ pub.cadence }}</p>
  {% if pub.description %}<p class="series-description">{{ pub.description }}</p>{% endif %}
  {% if pub.recent %}
  <ul class="series-recent" style="list-style:none;margin-top:0.75rem;display:flex;flex-direction:column;gap:0.4rem;">
    {% for post in pub.recent %}
    <li style="font-family:var(--mono);font-size:0.72rem;"><a href="{{ post.url }}" target="_blank" rel="noopener" style="color:var(--mid);text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--mid)'">→ {{ post.title }}</a></li>
    {% endfor %}
  </ul>
  {% endif %}
</div>
{% endfor %}

<div class="profile-link">
  <a href="{{ profile_url }}" target="_blank" rel="noopener">Personal profile on Medium →</a>
</div>

{% if note %}
<div class="writing-note">
  <p>{{ note }}</p>
</div>
{% endif %}

    </div>
  </main>

  <aside class="section-toc-aside" aria-label="On this page">
    {% if toc %}
    <span class="section-toc-label">On this page</span>
    <ul class="section-toc-links">
      {% for item in toc %}<li><a href="#{{ item.id }}">{{ item.label }}</a></li>{% endfor %}
    </ul>
    {% endif %}
  </aside>
</div>
