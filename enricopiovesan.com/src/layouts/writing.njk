---
layout: base.njk
---
{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://enricopiovesan.com/writing/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enricopiovesan.com/" },
        { "@type": "ListItem", "position": 2, "name": "Writing", "item": "https://enricopiovesan.com/writing/" }
      ]
    }
  ]
}
</script>
{% endblock %}

{% set nav = sectionNavs[sectionGroup] %}
<div class="section-shell">

  <aside class="section-nav-aside" aria-label="{{ nav.label }} navigation">
    {% if nav.url %}<a class="section-nav-label{% if page.url == nav.url %} active{% endif %}" href="{{ nav.url }}">{{ nav.label }}</a>{% else %}<span class="section-nav-label">{{ nav.label }}</span>{% endif %}
    {% if nav.links %}
    <ul class="section-nav-links">
      {% for link in nav.links %}
      <li><a href="{{ link.href }}"{% if page.url == link.href %} class="active" aria-current="page"{% endif %}>{{ link.label }}</a></li>
      {% endfor %}
    </ul>
    {% endif %}
  </aside>

  <main class="section-main">
    <nav class="section-breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        {% if breadcrumb %}
          {% for crumb in breadcrumb %}
            {% if loop.last %}<li><span aria-current="page">{{ crumb.label }}</span></li>
            {% else %}<li><a href="{{ crumb.href }}">{{ crumb.label }}</a></li>
            {% endif %}
          {% endfor %}
        {% else %}
        <li><span aria-current="page">Writing</span></li>
        {% endif %}
      </ol>
    </nav>

    <div class="section-body">
      <h1 class="section-h1">Writing</h1>
      {% if intro is string %}
      <p>{{ intro }}</p>
      {% else %}
        {% for para in intro %}
        <p>{{ para }}</p>
        {% endfor %}
      {% endif %}

      {% for pub in series %}
      <div class="writing-entry" id="{{ toc[loop.index0].id if toc[loop.index0] else '' }}">
        <span class="writing-entry-cadence">{{ pub.cadence }}</span>
        <h2 class="writing-entry-title"><a href="{{ pub.url }}" target="_blank" rel="noopener">{{ pub.name }}</a></h2>
        {% if pub.description %}<p>{{ pub.description }}</p>{% endif %}
        {% if pub.recent %}
        <div class="writing-entry-links">
          {% for post in pub.recent %}
          <a href="{{ post.url }}" target="_blank" rel="noopener">{{ post.title }}</a>
          {% endfor %}
        </div>
        {% endif %}
      </div>
      {% endfor %}

      {% if profile_url %}
      <div class="writing-entry">
        <p><a href="{{ profile_url }}" target="_blank" rel="noopener">Personal profile on Medium →</a></p>
      </div>
      {% endif %}
    </div>
  </main>

  <aside class="section-toc-aside" aria-label="On this page">
    {% if toc %}
    <span class="section-toc-label">On this page</span>
    <ul class="section-toc-links">
      {% for item in toc %}<li><a href="#{{ item.id }}">{{ item.label }}</a></li>{% endfor %}
    </ul>
    {% endif %}
  </aside>

</div>
