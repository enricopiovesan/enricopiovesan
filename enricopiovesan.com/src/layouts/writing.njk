---
layout: base.njk
---
{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enricopiovesan.com/" },
        { "@type": "ListItem", "position": 2, "name": "Writing", "item": "https://enricopiovesan.com/writing/" }
      ]
    },
    {
      "@type": "ItemList",
      "name": "Writing Series by Enrico Piovesan",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "item": {
            "@type": "Periodical",
            "name": "Mastering Software Architecture for the AI Era",
            "url": "https://medium.com/software-architecture-in-the-age-of-ai",
            "author": { "@id": "https://enricopiovesan.com/#person" },
            "about": ["Software Architecture", "AI-native Systems", "C-DAD"],
            "inLanguage": "en"
          }
        },
        {
          "@type": "ListItem",
          "position": 2,
          "item": {
            "@type": "Periodical",
            "name": "The Rise of Device-Independent Architecture",
            "url": "https://medium.com/the-rise-of-device-independent-architecture",
            "author": { "@id": "https://enricopiovesan.com/#person" },
            "about": ["WebAssembly", "UMA", "Device-Independent Architecture"],
            "inLanguage": "en"
          }
        }
      ]
    }
  ]
}
</script>
{% endblock %}
<section class="hero">
  <p class="hero-label">Medium</p>
  <h1>Writing</h1>
  {% if intro is string %}
  <p class="hero-bio">{{ intro }}</p>
  {% else %}
  {% for para in intro %}
  <p class="hero-bio" style="margin-top:{% if loop.first %}0{% else %}1rem{% endif %};">{{ para }}</p>
  {% endfor %}
  {% endif %}
</section>

{% for pub in series %}
<div class="writing-series">
  <div class="series-header">
    <div class="series-name"><a href="{{ pub.url }}" target="_blank" rel="noopener">{{ pub.name }}</a></div>
  </div>
  <p class="series-cadence">{{ pub.cadence }}</p>
  {% if pub.description %}<p class="series-description">{{ pub.description }}</p>{% endif %}
</div>
{% endfor %}

<div class="profile-link">
  <a href="{{ profile_url }}" target="_blank" rel="noopener">Personal profile on Medium →</a>
</div>

{% if note %}
<div class="writing-note">
  <p>{{ note }}</p>
</div>
{% endif %}
