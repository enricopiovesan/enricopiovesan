---
layout: base.njk
---
{% block schema %}
{% if canonical and canonical.includes('/concepts/') and not canonical.endsWith('/concepts/') %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "{{ canonical }}#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enricopiovesan.com/" },
        { "@type": "ListItem", "position": 2, "name": "Concepts", "item": "https://enricopiovesan.com/concepts/" },
        { "@type": "ListItem", "position": 3, "name": "{{ title }}", "item": "{{ canonical }}" }
      ]
    },
    {
      "@type": "TechArticle",
      "@id": "{{ canonical }}#article",
      "headline": "{{ title }}",
      "name": "{{ title }}",
      "description": "{{ description }}",
      "datePublished": "{{ datePublished }}",
      "dateModified": "2026-06-08",
      "author": { "@id": "https://enricopiovesan.com/#person" },
      "url": "{{ canonical }}",
      "inLanguage": "en",
      "isPartOf": { "@id": "https://enricopiovesan.com/#website" }
    }
  ]
}
</script>
{% endif %}
{% if canonical and canonical.includes('/whitepapers/') %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "{{ canonical }}#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enricopiovesan.com/" },
        { "@type": "ListItem", "position": 2, "name": "White Papers", "item": "https://enricopiovesan.com/whitepapers/" },
        { "@type": "ListItem", "position": 3, "name": "{{ title }}", "item": "{{ canonical }}" }
      ]
    },
    {
      "@type": "ScholarlyArticle",
      "@id": "{{ canonical }}#article",
      "headline": "{{ title }}",
      "name": "{{ title }}",
      "description": "{{ description }}",
      "datePublished": "{{ datePublished }}",
      "dateModified": "2026-06-08",
      "author": { "@id": "https://enricopiovesan.com/#person" },
      "publisher": { "@id": "https://enricopiovesan.com/#person" },
      "url": "{{ canonical }}",
      "inLanguage": "en",
      "isPartOf": { "@id": "https://enricopiovesan.com/#website" },
      "keywords": ["Software Architecture", "Platform Engineering", "WebAssembly", "AI-native Systems", "Contract-Driven Development"]
    }
  ]
}
</script>
{% endif %}
{% if canonical == "https://enricopiovesan.com/perspectives/" %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://enricopiovesan.com/perspectives/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enricopiovesan.com/" },
        { "@type": "ListItem", "position": 2, "name": "Perspectives", "item": "https://enricopiovesan.com/perspectives/" }
      ]
    },
    {
      "@type": "ItemList",
      "@id": "https://enricopiovesan.com/perspectives/#list",
      "name": "Perspectives on AI Engineering & Software Architecture",
      "description": "Takes on context engineering, AI-native architecture, and software design for agentic systems.",
      "author": { "@id": "https://enricopiovesan.com/#person" },
      "url": "https://enricopiovesan.com/perspectives/",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "url": "https://enricopiovesan.com/perspectives/context-engineering/",
          "name": "Beyond Context Engineering"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "url": "https://enricopiovesan.com/perspectives/ai-native-architecture/",
          "name": "What Makes Software AI-Native?"
        }
      ]
    }
  ]
}
</script>
{% endif %}
{% if canonical and canonical.includes('/perspectives/') and not canonical.endsWith('/perspectives/') %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "{{ canonical }}#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enricopiovesan.com/" },
        { "@type": "ListItem", "position": 2, "name": "Perspectives", "item": "https://enricopiovesan.com/perspectives/" },
        { "@type": "ListItem", "position": 3, "name": "{{ title }}", "item": "{{ canonical }}" }
      ]
    },
    {
      "@type": "BlogPosting",
      "@id": "{{ canonical }}#article",
      "headline": "{{ title }}",
      "name": "{{ title }}",
      "description": "{{ description }}",
      "datePublished": "{{ datePublished }}",
      "dateModified": "{{ datePublished }}",
      "author": { "@id": "https://enricopiovesan.com/#person" },
      "url": "{{ canonical }}",
      "inLanguage": "en",
      "isPartOf": { "@id": "https://enricopiovesan.com/perspectives/#list" }
    }
  ]
}
</script>
{% endif %}
{% endblock %}
<article class="page-content">
  <h1>{{ title | replace(" — Enrico Piovesan", "") }}</h1>
  {% if lastUpdated %}<p style="font-family:var(--mono);font-size:0.68rem;color:var(--mid);margin-bottom:2rem;">Last updated: {{ lastUpdated }}</p>{% endif %}
  {% if canonical and canonical.includes('/whitepapers/') and not canonical.endsWith('/whitepapers/') %}
  <p style="font-family:var(--mono);font-size:0.72rem;color:var(--mid);margin-bottom:2rem;border-left:2px solid var(--border);padding-left:0.75rem;">By <a href="/about/" style="color:var(--mid);text-decoration:underline;">Enrico Piovesan</a> — Platform Software Architect at Autodesk, author of <em>Universal Microservices Architecture</em> (Apress). Originator of UMA and C-DAD frameworks.</p>
  {% endif %}
  {{ content | safe }}
</article>
