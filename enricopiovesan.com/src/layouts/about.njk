---
layout: base.njk
---
{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enricopiovesan.com/" },
        { "@type": "ListItem", "position": 2, "name": "About", "item": "https://enricopiovesan.com/about/" }
      ]
    },
    {
      "@type": "Person",
      "@id": "https://enricopiovesan.com/#person",
      "alumniOf": {
        "@type": "Organization",
        "name": "Ford Motor Company"
      }
    }
  ]
}
</script>
{% endblock %}

<section class="hero">
  <p class="hero-label">{{ tagline }}</p>
  <h1>{{ name }}</h1>
</section>

<section class="bio-section">
  <p class="section-label">{{ role }}</p>
  <div class="bio-text">
    <picture>
      <source srcset="/src/assets/img/enrico-piovesan.webp" type="image/webp" />
      <img src="/src/assets/img/enrico-piovesan.jpg" alt="{{ name }}" class="headshot" width="80" height="80" loading="lazy" />
    </picture>
    <div class="bio-paragraphs">
      {% for para in bio %}
      <p>{{ para }}</p>
      {% endfor %}
    </div>
  </div>
</section>
