---
layout: base.njk
---
{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enricopiovesan.com/" },
        { "@type": "ListItem", "position": 2, "name": "About", "item": "https://enricopiovesan.com/about/" }
      ]
    },
    {
      "@type": "Person",
      "@id": "https://enricopiovesan.com/#person",
      "name": "Enrico Piovesan",
      "url": "https://enricopiovesan.com/",
      "jobTitle": "Platform Software Architect",
      "worksFor": {
        "@type": "Organization",
        "name": "Autodesk",
        "url": "https://www.autodesk.com"
      },
      "alumniOf": {
        "@type": "Organization",
        "name": "Ford Motor Company"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Golden",
        "addressRegion": "BC",
        "addressCountry": "CA"
      },
      "sameAs": [
        "https://github.com/enricopiovesan",
        "https://linkedin.com/in/enricopiovesan",
        "https://blog.enricopiovesan.com",
        "https://x.com/enricopiovesan",
        "https://www.amazon.com/dp/B0GTTTTQH4"
      ],
      "knowsAbout": ["Software Architecture", "WebAssembly", "Microservices", "AI-native Systems", "Platform Engineering"]
    }
  ]
}
</script>
{% endblock %}

<section class="hero">
  <p class="hero-label">{{ tagline }}</p>
  <h1>{{ name }}</h1>
</section>

<section class="bio-section">
  <p class="section-label">{{ role }}</p>
  <div class="bio-text">
    <img src="/src/assets/img/enrico-piovesan.jpg" alt="{{ name }}" class="headshot" width="120" height="120" loading="lazy" />
    {% for para in bio %}
    <p>{{ para }}</p>
    {% endfor %}
  </div>
</section>

<section class="links-section">
  {% for link in links %}
  <a class="contact-link" href="{{ link.url }}" target="_blank" rel="noopener">{{ link.label }}</a>
  {% endfor %}
</section>

<section class="contact-section">
  <p class="section-label">Get in touch</p>
  <div class="contact-cta">
    <p class="contact-cta-text">Speaking invitations, collaborations, or just a question about the work.</p>
    <a class="contact-cta-link" href="https://linkedin.com/in/enricopiovesan" target="_blank" rel="noopener">Connect on LinkedIn →</a>
  </div>
</section>
