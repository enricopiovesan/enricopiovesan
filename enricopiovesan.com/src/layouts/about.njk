---
layout: base.njk
---
{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://enricopiovesan.com/about/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enricopiovesan.com/" },
        { "@type": "ListItem", "position": 2, "name": "About", "item": "https://enricopiovesan.com/about/" }
      ]
    },
    {
      "@type": "Person",
      "@id": "https://enricopiovesan.com/#person",
      "alumniOf": {
        "@type": "Organization",
        "name": "Ford Motor Company"
      }
    }
  ]
}
</script>
{% endblock %}

{% set nav = sectionNavs[sectionGroup] %}
{% set autoToc = content | extractToc %}
<div class="section-shell">

  <aside class="section-nav-aside" aria-label="{{ nav.label }} navigation">
    {% if nav.url %}<a class="section-nav-label" href="{{ nav.url }}">{{ nav.label }}</a>{% else %}<span class="section-nav-label">{{ nav.label }}</span>{% endif %}
    {% if nav.links %}
    <ul class="section-nav-links">
      {% for link in nav.links %}
      <li><a href="{{ link.href }}"{% if page.url == link.href %} class="active" aria-current="page"{% endif %}>{{ link.label }}</a></li>
      {% endfor %}
    </ul>
    {% endif %}
  </aside>

  <main class="section-main">
    <nav class="section-breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        {% if breadcrumb %}
          {% for crumb in breadcrumb %}
            {% if loop.last %}<li><span aria-current="page">{{ crumb.label }}</span></li>
            {% else %}<li><a href="{{ crumb.href }}">{{ crumb.label }}</a></li>
            {% endif %}
          {% endfor %}
        {% else %}
        <li><span aria-current="page">{{ title }}</span></li>
        {% endif %}
      </ol>
    </nav>

    <div class="section-body">
      <p class="about-tagline">{{ tagline }}</p>
      <div class="about-header">
        <picture>
          <source srcset="/src/assets/img/enrico-piovesan.webp" type="image/webp" />
          <img src="/src/assets/img/enrico-piovesan.jpg" alt="{{ name }}" class="headshot" width="80" height="80" loading="lazy" />
        </picture>
        <h1 class="section-h1">{{ name }}</h1>
      </div>
      {{ content | safe }}
    </div>
  </main>

  <aside class="section-toc-aside" aria-label="On this page">
    {% if autoToc.length %}
    <span class="section-toc-label">On this page</span>
    <ul class="section-toc-links">
      {% for item in autoToc %}
      <li><a href="#{{ item.id }}">{{ item.label }}</a></li>
      {% endfor %}
    </ul>
    {% endif %}
  </aside>

</div>
