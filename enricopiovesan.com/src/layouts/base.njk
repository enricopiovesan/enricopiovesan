<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{% if page.fileSlug and page.fileSlug !== 'home' %}{{ title }} — Enrico Piovesan{% else %}Enrico Piovesan — Platform Architect &amp; Author{% endif %}</title>
  <meta name="description" content="{{ description }}" />

  <!-- Open Graph -->
  <meta property="og:title" content="{{ ogTitle or title }}" />
  <meta property="og:description" content="{{ ogDescription or description }}" />
  <meta property="og:image" content="https://enricopiovesan.com/public/og-default.png" />
  <meta property="og:url" content="https://enricopiovesan.com{{ page.url }}" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Enrico Piovesan" />

  <!-- Canonical -->
  <link rel="canonical" href="https://enricopiovesan.com{{ page.url }}" />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-71P091V6MQ"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-71P091V6MQ');
  </script>

  <!-- Fonts (self-hosted) -->

  <!-- Styles -->
  <link rel="stylesheet" href="/src/assets/styles/tokens.css" />
  <link rel="stylesheet" href="/src/assets/styles/reset.css" />
  <link rel="stylesheet" href="/src/assets/styles/global.css" />

  <!-- Schema -->
  {% block schema %}{% endblock %}

  <!-- Web Components -->
  <script type="module" src="/src/components/ep-nav.js"></script>
  <script type="module" src="/src/components/ep-footer.js"></script>
</head>
<body>
  <ep-nav active="{{ page.fileSlug }}" base="{{ pathPrefix }}"></ep-nav>

  <main id="main-content">
    {{ content | safe }}
  </main>

  <ep-footer></ep-footer>
</body>
</html>
