---
layout: base.njk
---
<section class="hero">
  <p class="hero-label">Platform architect. Author. Open source builder.</p>
  <h1>{{ hero }}</h1>
  <p class="hero-bio">{{ intro[0] }}</p>
</section>

<section class="section">
  <p class="section-label">The work</p>
  <p style="font-size:0.95rem;color:var(--mid);line-height:1.8;max-width:520px;margin-bottom:2rem;">{{ intro[1] }}</p>
</section>

<div class="nav-cards">
  {% for card in nav_cards %}
  <a class="nav-card" href="{{ card.href }}">
    <span class="nav-card-label">{{ card.label }}</span>
    <span class="nav-card-desc">{{ card.desc }}</span>
  </a>
  {% endfor %}
</div>

<section class="bio-section">
  <p class="section-label">Bio</p>
  <div class="bio-text"><p>{{ bio }}</p></div>
</section>

<section class="links-section">
  {% for link in links %}
  <a class="contact-link" href="{{ link.url }}" target="_blank" rel="noopener">{{ link.label }}</a>
  {% endfor %}
</section>
