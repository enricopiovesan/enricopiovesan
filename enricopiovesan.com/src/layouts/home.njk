---
layout: base.njk
---
{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://enricopiovesan.com/#homepage",
      "url": "https://enricopiovesan.com/",
      "name": "Enrico Piovesan - Platform Architect & Author",
      "description": "Platform architect and author building frameworks for software that runs anywhere and codebases that AI agents can actually navigate.",
      "about": { "@id": "https://enricopiovesan.com/#person" }
    },
    { "@id": "https://enricopiovesan.com/#person" },
    {
      "@type": "WebSite",
      "@id": "https://enricopiovesan.com/#website",
      "url": "https://enricopiovesan.com/",
      "name": "Enrico Piovesan",
      "description": "Platform architect and author. Software that runs anywhere.",
      "publisher": { "@id": "https://enricopiovesan.com/#person" },
      "inLanguage": "en"
    }
  ]
}
</script>
{% endblock %}

<div class="home-wrap">

  {# ── HERO ───────────────────────────────────────────── #}
  <header class="home-hero">
    <div class="home-hero-content">
      <h1 class="home-tagline">Software should work for <em>users</em>, not for the runtime it happens to run on.</h1>

      <p class="home-intro">{{ intro }}</p>
    </div>
  </header>

  {# ── SECTIONS ───────────────────────────────────────── #}
  <div class="home-body">

    <section class="home-section">
      <h2 class="home-section-label">The work</h2>
      <ul class="home-work-list">
        {% for item in work %}
        <li class="home-work-item">
          <a class="home-work-link" href="{{ item.href }}">
            <span class="home-work-name">{{ item.label }}</span>
            <span class="home-work-arrow">→</span>
          </a>
          <span class="home-work-desc">{{ item.desc }}</span>
        </li>
        {% endfor %}
      </ul>
    </section>

    <section class="home-section">
      <h2 class="home-section-label">The frameworks</h2>
      <div class="home-frameworks">
        {% for fw in frameworks %}
        <a class="home-framework-card" href="{{ fw.href }}">
          <span class="home-framework-abbr"><abbr title="{{ fw.abbr_title }}">{{ fw.abbr }}</abbr></span>
          <span class="home-framework-name">{{ fw.name }}</span>
          <span class="home-framework-desc">{{ fw.desc }}</span>
        </a>
        {% endfor %}
      </div>
    </section>

  </div>

  {# ── RECENT WRITING ─────────────────────────────────── #}
  {% if blogPosts and blogPosts.length %}
  <section class="home-posts">
    <h2 class="home-section-label home-posts-label">Recent writing</h2>
    <ul class="home-posts-grid">
      {% for post in blogPosts %}
      <li class="home-post-card">
        <a class="home-post-card-link" href="{{ post.url }}" target="_blank" rel="noopener">
          {% if post.image %}
          <div class="home-post-img-wrap">
            <img class="home-post-img" src="{{ post.image }}" alt="{{ post.title }}" loading="lazy" width="320" height="180">
          </div>
          {% endif %}
          <div class="home-post-body">
            <span class="home-post-title">{{ post.title }}</span>
            <span class="home-post-meta">
              {% if post.date %}<span class="home-post-date">{{ post.date }}</span>{% endif %}
              {% if post.tags.length %}
              <span class="home-post-tags">
                {% for tag in post.tags %}<span class="home-post-tag">{{ tag }}</span>{% endfor %}
              </span>
              {% endif %}
            </span>
          </div>
        </a>
      </li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

</div>
