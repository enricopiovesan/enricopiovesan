---
layout: base.njk
---
{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProfilePage",
      "@id": "https://enricopiovesan.com/#profilepage",
      "url": "https://enricopiovesan.com/",
      "name": "Enrico Piovesan - Platform Architect & Author",
      "description": "Platform architect and author building frameworks for software that runs anywhere and codebases that AI agents can actually navigate.",
      "mainEntity": { "@id": "https://enricopiovesan.com/#person" }
    },
    {
      "@type": "Person",
      "@id": "https://enricopiovesan.com/#person",
      "name": "Enrico Piovesan",
      "url": "https://enricopiovesan.com/",
      "jobTitle": "Platform Software Architect",
      "worksFor": {
        "@type": "Organization",
        "name": "Autodesk",
        "url": "https://www.autodesk.com"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Golden",
        "addressRegion": "BC",
        "addressCountry": "CA"
      },
      "sameAs": [
        "https://github.com/enricopiovesan",
        "https://linkedin.com/in/enricopiovesan",
        "https://medium.com/@enricopiovesan",
        "https://x.com/enricopiovesan",
        "https://www.amazon.com/dp/B0GTTTTQH4"
      ],
      "knowsAbout": ["Software Architecture", "WebAssembly", "Microservices", "AI-native Systems", "Platform Engineering"]
    },
    {
      "@type": "WebSite",
      "@id": "https://enricopiovesan.com/#website",
      "url": "https://enricopiovesan.com/",
      "name": "Enrico Piovesan",
      "description": "Platform architect and author. Software that runs anywhere.",
      "publisher": { "@id": "https://enricopiovesan.com/#person" },
      "inLanguage": "en"
    }
  ]
}
</script>
{% endblock %}
<section class="hero">
  <p class="hero-label">Platform architect. Author. Open source builder.</p>
  <h1>{{ hero }}</h1>
  <p class="hero-bio">{{ intro[0] }}</p>
</section>

<section class="section">
  <p class="section-label">The work</p>
  <p style="font-size:0.95rem;color:var(--mid);line-height:1.8;max-width:520px;margin-bottom:2rem;">{{ intro[1] }}</p>
</section>

<div class="nav-cards">
  {% for card in nav_cards %}
  <a class="nav-card" href="{{ card.href }}">
    <span class="nav-card-label">{{ card.label }}</span>
    <span class="nav-card-desc">{{ card.desc }}</span>
  </a>
  {% endfor %}
</div>

<section class="bio-section">
  <p class="section-label">Bio</p>
  <div class="bio-text">
    <picture>
      <source srcset="/src/assets/img/enrico-piovesan.webp" type="image/webp" />
      <img src="/src/assets/img/enrico-piovesan.jpg" alt="Enrico Piovesan" class="headshot" width="80" height="80" fetchpriority="low" />
    </picture>
    <p>{{ bio }} <a href="{{ about_href }}" style="color:var(--accent);text-decoration:underline;">About →</a></p>
  </div>
</section>
