---
layout: base.njk
---
{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProfilePage",
      "@id": "https://enricopiovesan.com/#profilepage",
      "url": "https://enricopiovesan.com/",
      "name": "Enrico Piovesan - Platform Architect & Author",
      "description": "Platform architect and author building frameworks for software that runs anywhere and codebases that AI agents can actually navigate.",
      "mainEntity": { "@id": "https://enricopiovesan.com/#person" }
    },
    { "@id": "https://enricopiovesan.com/#person" },
    {
      "@type": "WebSite",
      "@id": "https://enricopiovesan.com/#website",
      "url": "https://enricopiovesan.com/",
      "name": "Enrico Piovesan",
      "description": "Platform architect and author. Software that runs anywhere.",
      "publisher": { "@id": "https://enricopiovesan.com/#person" },
      "inLanguage": "en"
    }
  ]
}
</script>
{% endblock %}
<section class="hero">
  <p class="hero-label">Platform architect. Author. Open source builder.</p>
  <h1>{{ hero }}</h1>
  <p class="hero-bio">{{ intro[0] }}</p>
  <p style="font-family:var(--mono);font-size:0.72rem;letter-spacing:0.04em;color:var(--mid);margin-top:1.5rem;">Platform Software Architect at Autodesk · 1 published book (Apress) · 5 white papers · 4 open source projects</p>
</section>

<section class="section">
  <p class="section-label">The work</p>
  <p style="font-size:0.95rem;color:var(--mid);line-height:1.8;max-width:520px;margin-bottom:2rem;">{{ intro[1] }}</p>
</section>

<div class="nav-cards">
  {% for card in nav_cards %}
  <a class="nav-card" href="{{ card.href }}">
    <span class="nav-card-label">{{ card.label }}</span>
    <span class="nav-card-desc">{{ card.desc }}</span>
  </a>
  {% endfor %}
</div>

