---
layout: base.njk
---
<section class="hero">
  <p class="hero-label">White Papers</p>
  <h1>{{ intro }}</h1>
</section>

{% for paper in papers %}
<div class="paper">
  <div class="paper-header">
    <div class="paper-title">
      <a href="{{ paper.url }}" target="_blank" rel="noopener">{{ paper.title }}</a>
    </div>
    <span class="paper-date">{{ paper.date }}</span>
  </div>
  {% if paper.description %}<p class="paper-description">{{ paper.description }}</p>{% endif %}
</div>
{% endfor %}
