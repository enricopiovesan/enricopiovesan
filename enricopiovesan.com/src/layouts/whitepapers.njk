---
layout: base.njk
---
{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enricopiovesan.com/" },
        { "@type": "ListItem", "position": 2, "name": "White Papers", "item": "https://enricopiovesan.com/whitepapers/" }
      ]
    },
    {
      "@type": "ScholarlyArticle",
      "@id": "https://enricopiovesan.com/whitepapers/#cdad",
      "name": "Contract-Driven AI Development (C-DAD)",
      "description": "A foundation for building AI-native systems where contracts, not code, define collaboration between humans, machines, and runtimes.",
      "author": { "@id": "https://enricopiovesan.com/#person" },
      "datePublished": "2025-11-01",
      "inLanguage": "en"
    },
    {
      "@type": "ScholarlyArticle",
      "@id": "https://enricopiovesan.com/whitepapers/#ecca",
      "name": "Event Contract Catalog Architecture (ECCA)",
      "description": "A blueprint for an event contract catalog that treats events as first-class architectural artifacts with declared contracts, ownership, and lifecycle.",
      "author": { "@id": "https://enricopiovesan.com/#person" },
      "datePublished": "2025-08-01",
      "inLanguage": "en"
    },
    {
      "@type": "ScholarlyArticle",
      "@id": "https://enricopiovesan.com/whitepapers/#uma",
      "name": "Universal Microservices Architecture (UMA)",
      "description": "The foundational paper introducing UMA as a portable, contract-driven execution model for distributed systems.",
      "author": { "@id": "https://enricopiovesan.com/#person" },
      "datePublished": "2024-08-01",
      "inLanguage": "en"
    },
    {
      "@type": "ScholarlyArticle",
      "@id": "https://enricopiovesan.com/whitepapers/#csma",
      "name": "Client-Side Microservices Architecture (CSMA)",
      "description": "The original paper introducing client-side microservices as a pattern for portable, composable business logic running in the browser.",
      "author": { "@id": "https://enricopiovesan.com/#person" },
      "datePublished": "2023-06-01",
      "inLanguage": "en"
    }
  ]
}
</script>
{% endblock %}
<section class="hero">
  <p class="hero-label">White Papers</p>
  <h1>{{ intro }}</h1>
</section>

{% for paper in papers %}
<div class="paper">
  <div class="paper-inner">
    {% if paper.image %}
    <a class="paper-cover-link" href="{{ paper.url }}" target="_blank" rel="noopener">
      <img src="{{ paper.image }}" alt="{{ paper.title }} cover" class="paper-cover" width="80" height="113" loading="lazy" />
    </a>
    {% endif %}
    <div class="paper-body">
      <div class="paper-header">
        <div class="paper-title">
          <a href="{{ paper.url }}" target="_blank" rel="noopener">{{ paper.title }}</a>
        </div>
        <span class="paper-date">{{ paper.date }}</span>
      </div>
      {% if paper.description %}<p class="paper-description">{{ paper.description }}</p>{% endif %}
    </div>
  </div>
</div>
{% endfor %}
