---
layout: base.njk
---
{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://enricopiovesan.com/whitepapers/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enricopiovesan.com/" },
        { "@type": "ListItem", "position": 2, "name": "White Papers", "item": "https://enricopiovesan.com/whitepapers/" }
      ]
    }
  ]
}
</script>
{% endblock %}

{% set nav = sectionNavs[sectionGroup] %}
<div class="section-shell">

  <aside class="section-nav-aside" aria-label="{{ nav.label }} navigation">
    {% if nav.url %}<a class="section-nav-label{% if page.url == nav.url %} active{% endif %}" href="{{ nav.url }}">{{ nav.label }}</a>{% else %}<span class="section-nav-label">{{ nav.label }}</span>{% endif %}
    {% if nav.links %}
    <ul class="section-nav-links">
      {% for link in nav.links %}
      <li><a href="{{ link.href }}"{% if page.url == link.href %} class="active" aria-current="page"{% endif %}>{{ link.label }}</a></li>
      {% endfor %}
    </ul>
    {% endif %}
  </aside>

  <main class="section-main">
    <nav class="section-breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        {% if breadcrumb %}
          {% for crumb in breadcrumb %}
            {% if loop.last %}<li><span aria-current="page">{{ crumb.label }}</span></li>
            {% else %}<li><a href="{{ crumb.href }}">{{ crumb.label }}</a></li>
            {% endif %}
          {% endfor %}
        {% else %}
        <li><span aria-current="page">White Papers</span></li>
        {% endif %}
      </ol>
    </nav>

    <div class="section-body">
      <h1 class="section-h1">White Papers</h1>
      <p>{{ intro }}</p>

      {% for paper in papers %}
      <div class="paper-entry" id="{{ paper.id }}">
        <div class="paper-entry-header">
          <time class="paper-entry-date">{{ paper.date }}</time>
          <a class="paper-entry-title" href="{{ paper.page or paper.url }}"{% if not paper.page %} target="_blank" rel="noopener"{% endif %}>{{ paper.title }}</a>
        </div>
        <div class="paper-entry-body">
          {% if paper.image %}
          <a class="paper-entry-cover-link" href="{{ paper.page or paper.url }}"{% if not paper.page %} target="_blank" rel="noopener"{% endif %}>
            <img src="{{ paper.image }}" alt="{{ paper.title }}" class="paper-entry-cover" width="70" loading="lazy" />
          </a>
          {% endif %}
          <div class="paper-entry-text">
            {% if paper.description %}<p>{{ paper.description }}</p>{% endif %}
            <div class="paper-entry-links">
              {% if paper.page %}<a href="{{ paper.page }}">Read →</a>{% endif %}
              {% if paper.url %}<a href="{{ paper.url }}" target="_blank" rel="noopener">Download PDF →</a>{% endif %}
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </main>

  <aside class="section-toc-aside" aria-label="On this page">
    {% if toc %}
    <span class="section-toc-label">On this page</span>
    <ul class="section-toc-links">
      {% for item in toc %}<li><a href="#{{ item.id }}">{{ item.label }}</a></li>{% endfor %}
    </ul>
    {% endif %}
  </aside>

</div>
