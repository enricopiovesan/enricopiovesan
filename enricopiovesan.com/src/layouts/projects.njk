{% endblock %}

{% set nav = sectionNavs[sectionGroup] %}
<div class="section-shell">
  <aside class="section-nav-aside" aria-label="{{ nav.label }} navigation">
    {% if nav.url %}<a class="section-nav-label" href="{{ nav.url }}">{{ nav.label }}</a>{% else %}<span class="section-nav-label">{{ nav.label }}</span>{% endif %}
    {% if nav.links %}
    <ul class="section-nav-links">
      {% for link in nav.links %}
      <li><a href="{{ link.href }}"{% if page.url == link.href %} class="active" aria-current="page"{% endif %}>{{ link.label }}</a></li>
      {% endfor %}
    </ul>
    {% endif %}
  </aside>

  <main class="section-main">
    <nav class="section-breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        {% if breadcrumb %}
          {% for crumb in breadcrumb %}
            {% if loop.last %}<li><span aria-current="page">{{ crumb.label }}</span></li>
            {% else %}<li><a href="{{ crumb.href }}">{{ crumb.label }}</a></li>
            {% endif %}
          {% endfor %}
        {% else %}
        <li><span aria-current="page">{{ title }}</span></li>
        {% endif %}
      </ol>
    </nav>

    <div class="section-body">

<section class="hero">
  <p class="hero-label">Open Source</p>
  <h1>Projects</h1>
  <p class="hero-bio">{{ intro }}</p>
</section>

{% for project in projects %}
<div class="project">
  <div class="project-header">
    <h2 class="project-title">{{ project.title }}</h2>
    <span class="project-status">{{ project.status }}</span>
  </div>
  <div class="project-meta">
    {% if project.type %}<span class="project-type">{{ project.type }}</span>{% endif %}
    {% if project.stack %}<span>{{ project.stack }}</span>{% endif %}
  </div>
  {% if project.description %}<p class="project-description">{{ project.description }}</p>{% endif %}
  <div class="project-links">
    {% if project.github %}<a href="{{ project.github }}" target="_blank" rel="noopener">github →</a>{% endif %}
    {% if project.url %}<a href="{{ project.url }}" target="_blank" rel="noopener">site →</a>{% endif %}
  </div>
</div>
{% endfor %}

    </div>
  </main>

  <aside class="section-toc-aside" aria-label="On this page">
    {% if toc %}
    <span class="section-toc-label">On this page</span>
    <ul class="section-toc-links">
      {% for item in toc %}<li><a href="#{{ item.id }}">{{ item.label }}</a></li>{% endfor %}
    </ul>
    {% endif %}
  </aside>
</div>
