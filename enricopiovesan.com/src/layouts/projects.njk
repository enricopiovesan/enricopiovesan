---
layout: base.njk
---
{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://enricopiovesan.com/projects/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enricopiovesan.com/" },
        { "@type": "ListItem", "position": 2, "name": "Projects", "item": "https://enricopiovesan.com/projects/" }
      ]
    }
  ]
}
</script>
{% endblock %}

{% set nav = sectionNavs[sectionGroup] %}
<div class="section-shell">

  <aside class="section-nav-aside" aria-label="{{ nav.label }} navigation">
    {% if nav.url %}<a class="section-nav-label{% if page.url == nav.url %} active{% endif %}" href="{{ nav.url }}">{{ nav.label }}</a>{% else %}<span class="section-nav-label">{{ nav.label }}</span>{% endif %}
    {% if nav.links %}
    <ul class="section-nav-links">
      {% for link in nav.links %}
      <li><a href="{{ link.href }}"{% if page.url == link.href %} class="active" aria-current="page"{% endif %}>{{ link.label }}</a></li>
      {% endfor %}
    </ul>
    {% endif %}
  </aside>

  <main class="section-main">
    <nav class="section-breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        {% if breadcrumb %}
          {% for crumb in breadcrumb %}
            {% if loop.last %}<li><span aria-current="page">{{ crumb.label }}</span></li>
            {% else %}<li><a href="{{ crumb.href }}">{{ crumb.label }}</a></li>
            {% endif %}
          {% endfor %}
        {% else %}
        <li><span aria-current="page">Projects</span></li>
        {% endif %}
      </ol>
    </nav>

    <div class="section-body">
      <h1 class="section-h1">Projects</h1>
      <p>{{ intro }}</p>

      <h2 class="section-body-section-label" id="architecture-projects">Architecture projects</h2>
      {% for project in projects %}
      <div class="project-entry" id="{{ project.id }}">
        <div class="project-entry-header">
          <span class="project-entry-meta">
            {% if project.type %}{{ project.type }}{% endif %}
            {% if project.stack %} · {{ project.stack }}{% endif %}
          </span>
          <span class="project-entry-status">{{ project.status }}</span>
        </div>
        <h2 class="project-entry-title">{{ project.title }}</h2>
        {% if project.description %}<p>{{ project.description }}</p>{% endif %}
        <div class="project-entry-links">
          {% if project.github %}<a href="{{ project.github }}" target="_blank" rel="noopener">GitHub →</a>{% endif %}
          {% if project.url %}<a href="{{ project.url }}" target="_blank" rel="noopener">Site →</a>{% endif %}
        </div>
      </div>
      {% endfor %}

      {% if community %}
      <h2 class="section-body-section-label" id="community-projects">Community projects</h2>
      {% for project in community %}
      <div class="project-entry" id="{{ project.id }}">
        <div class="project-entry-header">
          <span class="project-entry-meta">{{ project.type }}</span>
          <span class="project-entry-status">{{ project.status }}</span>
        </div>
        <h2 class="project-entry-title">{{ project.title }}</h2>
        {% if project.description %}<p>{{ project.description }}</p>{% endif %}
        <div class="project-entry-links">
          {% if project.github %}<a href="{{ project.github }}" target="_blank" rel="noopener">GitHub →</a>{% endif %}
          {% if project.url %}<a href="{{ project.url }}" target="_blank" rel="noopener">Site →</a>{% endif %}
        </div>
      </div>
      {% endfor %}
      {% endif %}
    </div>
  </main>

  <aside class="section-toc-aside" aria-label="On this page">
    {% if toc %}
    <span class="section-toc-label">On this page</span>
    <ul class="section-toc-links">
      {% for item in toc %}<li><a href="#{{ item.id }}">{{ item.label }}</a></li>{% endfor %}
    </ul>
    {% endif %}
  </aside>

</div>
