---
layout: base.njk
---
{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enricopiovesan.com/" },
        { "@type": "ListItem", "position": 2, "name": "Projects", "item": "https://enricopiovesan.com/projects/" }
      ]
    },
    {
      "@type": "SoftwareSourceCode",
      "name": "UMA-code-examples",
      "description": "13 chapters of runnable code companion to Universal Microservices Architecture. 100% business logic coverage enforced in CI.",
      "codeRepository": "https://github.com/enricopiovesan/UMA-code-examples",
      "programmingLanguage": ["Rust", "WebAssembly", "JavaScript"],
      "author": { "@id": "https://enricopiovesan.com/#person" },
      "url": "https://www.universalmicroservices.com"
    },
    {
      "@type": "SoftwareSourceCode",
      "name": "the-day-after-toolkit",
      "description": "A CLI that audits codebase agent-readiness and scaffolds the contracts needed to fix it.",
      "codeRepository": "https://github.com/enricopiovesan/the-day-after-toolkit",
      "programmingLanguage": "TypeScript",
      "author": { "@id": "https://enricopiovesan.com/#person" }
    },
    {
      "@type": "SoftwareSourceCode",
      "name": "Traverse",
      "description": "A contract-driven Rust/WASM runtime for discovering, validating, and composing portable business capabilities.",
      "codeRepository": "https://github.com/enricopiovesan/Traverse",
      "programmingLanguage": "Rust",
      "author": { "@id": "https://enricopiovesan.com/#person" }
    }
  ]
}
</script>
{% endblock %}
<section class="hero">
  <p class="hero-label">Projects</p>
  <h1>{{ intro }}</h1>
</section>

{% for project in projects %}
<div class="project">
  <div class="project-header">
    <span class="project-title">{{ project.title }}</span>
    <span class="project-status">{{ project.status }}</span>
  </div>
  <div class="project-meta">
    {% if project.type %}<span class="project-type">{{ project.type }}</span>{% endif %}
    {% if project.stack %}<span>{{ project.stack }}</span>{% endif %}
  </div>
  {% if project.description %}<p class="project-description">{{ project.description }}</p>{% endif %}
  <div class="project-links">
    {% if project.github %}<a href="{{ project.github }}" target="_blank" rel="noopener">github →</a>{% endif %}
    {% if project.url %}<a href="{{ project.url }}" target="_blank" rel="noopener">site →</a>{% endif %}
  </div>
</div>
{% endfor %}
