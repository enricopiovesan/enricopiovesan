---
layout: base.njk
---
{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://enricopiovesan.com/books/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enricopiovesan.com/" },
        { "@type": "ListItem", "position": 2, "name": "Books", "item": "https://enricopiovesan.com/books/" }
      ]
    },
    {
      "@type": "Book",
      "@id": "https://enricopiovesan.com/books/#uma-book",
      "name": "Universal Microservices Architecture",
      "author": { "@id": "https://enricopiovesan.com/#person" },
      "publisher": { "@type": "Organization", "name": "Apress" },
      "url": "https://www.amazon.com/dp/B0GTTTTQH4"
    },
    {
      "@type": "Book",
      "@id": "https://enricopiovesan.com/books/#the-day-after",
      "name": "The Day After",
      "author": { "@id": "https://enricopiovesan.com/#person" },
      "publisher": { "@type": "Organization", "name": "Apress" },
      "bookEdition": "Forthcoming"
    }
  ]
}
</script>
{% endblock %}

{% set nav = sectionNavs[sectionGroup] %}
<div class="section-shell">

  <aside class="section-nav-aside" aria-label="{{ nav.label }} navigation">
    {% if nav.url %}<a class="section-nav-label{% if page.url == nav.url %} active{% endif %}" href="{{ nav.url }}">{{ nav.label }}</a>{% else %}<span class="section-nav-label">{{ nav.label }}</span>{% endif %}
    {% if nav.links %}
    <ul class="section-nav-links">
      {% for link in nav.links %}
      <li><a href="{{ link.href }}"{% if page.url == link.href %} class="active" aria-current="page"{% endif %}>{{ link.label }}</a></li>
      {% endfor %}
    </ul>
    {% endif %}
  </aside>

  <main class="section-main">
    <nav class="section-breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        {% if breadcrumb %}
          {% for crumb in breadcrumb %}
            {% if loop.last %}<li><span aria-current="page">{{ crumb.label }}</span></li>
            {% else %}<li><a href="{{ crumb.href }}">{{ crumb.label }}</a></li>
            {% endif %}
          {% endfor %}
        {% else %}
        <li><span aria-current="page">Books</span></li>
        {% endif %}
      </ol>
    </nav>

    <div class="section-body">
      <h1 class="section-h1">Books</h1>
      <p>{{ intro }}</p>

      {% for book in books %}
      <div class="book-entry" id="{{ toc[loop.index0].id if toc[loop.index0] else '' }}">
        <div class="book-entry-header">
          <span class="book-entry-status">{{ book.status }}</span>
          {% if book.url %}
          <a class="book-entry-title" href="{{ book.url }}" target="_blank" rel="noopener">{{ book.title }}</a>
          {% else %}
          <span class="book-entry-title">{{ book.title }}</span>
          {% endif %}
        </div>
        <div class="book-entry-body">
          {% if book.cover %}
          <a class="book-entry-cover-link" {% if book.url %}href="{{ book.url }}" target="_blank" rel="noopener"{% endif %}>
            <img src="{{ book.cover }}" alt="{{ book.title }} cover" class="book-entry-cover" width="120" loading="lazy" />
          </a>
          {% endif %}
          <div class="book-entry-text">
            {% if book.description is string %}
            <p>{{ book.description }}</p>
            {% else %}
              {% for para in book.description %}
              <p>{{ para }}</p>
              {% endfor %}
            {% endif %}
            {% if book.audience %}
            <p class="book-entry-audience">For: {{ book.audience }}</p>
            {% endif %}
            <div class="book-entry-links">
              {% if book.url %}<a href="{{ book.url }}" target="_blank" rel="noopener">Amazon →</a>{% endif %}
              {% if book.website %}<a href="{{ book.website }}" target="_blank" rel="noopener">Website →</a>{% endif %}
              {% if book.companion_live %}<a href="{{ book.companion_live }}" target="_blank" rel="noopener">Reference app →</a>{% endif %}
              {% if book.companion_repo %}<a href="{{ book.companion_repo }}" target="_blank" rel="noopener">Companion repo →</a>{% endif %}
              {% if book.whitepaper %}<a href="{{ book.whitepaper }}">C-DAD white paper →</a>{% endif %}
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </main>

  <aside class="section-toc-aside" aria-label="On this page">
    {% if toc %}
    <span class="section-toc-label">On this page</span>
    <ul class="section-toc-links">
      {% for item in toc %}<li><a href="#{{ item.id }}">{{ item.label }}</a></li>{% endfor %}
    </ul>
    {% endif %}
  </aside>

</div>
