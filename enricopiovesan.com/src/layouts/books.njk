---
layout: base.njk
---
<section class="hero">
  <p class="hero-label">Books</p>
  <h1>{{ intro }}</h1>
</section>

{% for book in books %}
<div class="book">
  <div class="book-header">
    <div class="book-title">
      {% if book.url %}<a href="{{ book.url }}" target="_blank" rel="noopener">{{ book.title }}</a>{% else %}{{ book.title }}{% endif %}
    </div>
    <span class="book-status {{ book.status }}">{{ book.status }}</span>
  </div>
  {% if book.subtitle %}<div class="book-subtitle">{{ book.subtitle }}</div>{% endif %}
  {% if book.description %}<p class="book-description">{{ book.description }}</p>{% endif %}
  <div class="book-links">
    {% if book.url and book.publisher %}<a href="{{ book.url }}" target="_blank" rel="noopener">{{ book.publisher }} →</a>{% endif %}
    {% if book.companion_repo %}<a href="{{ book.companion_repo }}" target="_blank" rel="noopener">companion repo →</a>{% endif %}
    {% if book.companion_live %}<a href="{{ book.companion_live }}" target="_blank" rel="noopener">live reference →</a>{% endif %}
  </div>
</div>
{% endfor %}
