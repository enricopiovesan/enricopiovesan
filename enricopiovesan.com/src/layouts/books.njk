---
layout: base.njk
---
{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://enricopiovesan.com/books/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enricopiovesan.com/" },
        { "@type": "ListItem", "position": 2, "name": "Books", "item": "https://enricopiovesan.com/books/" }
      ]
    },
    {
      "@type": "Book",
      "@id": "https://enricopiovesan.com/books/#uma-book",
      "name": "Universal Microservices Architecture",
      "subtitle": "Device-Independent Modelling for Modern Software Design with WASM",
      "url": "https://www.amazon.com/dp/B0GTTTTQH4",
      "sameAs": "https://www.amazon.com/dp/B0GTTTTQH4",
      "identifier": { "@type": "PropertyValue", "propertyID": "ASIN", "value": "B0GTTTTQH4" },
      "author": { "@id": "https://enricopiovesan.com/#person" },
      "publisher": { "@type": "Organization", "name": "Apress", "url": "https://www.apress.com" },
      "datePublished": "2024-01-01",
      "inLanguage": "en",
      "bookFormat": "EBook",
      "genre": ["Software Architecture", "WebAssembly", "Distributed Systems"]
    },
    {
      "@type": "Book",
      "@id": "https://enricopiovesan.com/books/#the-day-after",
      "name": "The Day After",
      "subtitle": "How to Restructure Your Software Company for the Age of AI Agents",
      "url": "https://enricopiovesan.com/books/",
      "author": { "@id": "https://enricopiovesan.com/#person" },
      "publisher": { "@type": "Organization", "name": "Apress", "url": "https://www.apress.com" },
      "inLanguage": "en",
      "bookFormat": "EBook",
      "datePublished": "2026-01-01",
      "bookEdition": "Forthcoming",
      "genre": ["Software Architecture", "AI Engineering", "Engineering Leadership"]
    }
  ]
}
</script>
{% endblock %}

{% set nav = sectionNavs[sectionGroup] %}
<div class="section-shell">
  <aside class="section-nav-aside" aria-label="{{ nav.label }} navigation">
    {% if nav.url %}<a class="section-nav-label" href="{{ nav.url }}">{{ nav.label }}</a>{% else %}<span class="section-nav-label">{{ nav.label }}</span>{% endif %}
    {% if nav.links %}
    <ul class="section-nav-links">
      {% for link in nav.links %}
      <li><a href="{{ link.href }}"{% if page.url == link.href %} class="active" aria-current="page"{% endif %}>{{ link.label }}</a></li>
      {% endfor %}
    </ul>
    {% endif %}
  </aside>

  <main class="section-main">
    <nav class="section-breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        {% if breadcrumb %}
          {% for crumb in breadcrumb %}
            {% if loop.last %}<li><span aria-current="page">{{ crumb.label }}</span></li>
            {% else %}<li><a href="{{ crumb.href }}">{{ crumb.label }}</a></li>
            {% endif %}
          {% endfor %}
        {% else %}
        <li><span aria-current="page">{{ title }}</span></li>
        {% endif %}
      </ol>
    </nav>

    <div class="section-body">

<section class="hero">
  <p class="hero-label">Published Work</p>
  <h1>Books</h1>
  <p class="hero-bio">{{ intro }}</p>
  <p style="font-family:var(--mono);font-size:0.72rem;letter-spacing:0.04em;color:var(--mid);margin-top:1rem;">Published by Apress · Platform Software Architect at Autodesk</p>
  <div style="margin-top:1.5rem;">
    <a href="https://www.amazon.com/dp/B0GTTTTQH4" target="_blank" rel="noopener" style="font-family:var(--mono);font-size:0.78rem;color:var(--fg);border:1px solid var(--border);padding:0.6rem 1.2rem;text-decoration:none;transition:opacity 0.15s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">Buy on Amazon →</a>
  </div>
</section>

{% for book in books %}
<div class="book">
  <div class="book-inner">
    {% if book.cover %}
    <a class="book-cover-link" {% if book.url %}href="{{ book.url }}" target="_blank" rel="noopener"{% endif %}>
      <img src="{{ book.cover }}" alt="{{ book.title }} cover" class="book-cover" width="160" height="233" loading="lazy" />
    </a>
    {% endif %}
    <div class="book-body">
      <div class="book-header">
        <h2 class="book-title">
          {% if book.url %}<a href="{{ book.url }}" target="_blank" rel="noopener">{{ book.title }}</a>{% else %}{{ book.title }}{% endif %}
        </h2>
        <span class="book-status {{ book.status }}">{{ book.status }}</span>
      </div>
      {% if book.description is string %}
        <p class="book-description">{{ book.description }}</p>
      {% else %}
        {% for para in book.description %}
        <p class="book-description">{{ para }}</p>
        {% endfor %}
      {% endif %}
      {% if book.audience %}
      <p class="book-audience"><strong>For:</strong> {{ book.audience }}</p>
      {% endif %}
      <div class="book-links">
        {% if book.url and book.publisher %}<a href="{{ book.url }}" target="_blank" rel="noopener">{{ book.publisher }} →</a>{% endif %}
        {% if book.website %}<a href="{{ book.website }}" target="_blank" rel="noopener">website →</a>{% endif %}
        {% if book.companion_live %}<a href="{{ book.companion_live }}" target="_blank" rel="noopener">reference app →</a>{% endif %}
        {% if book.companion_repo %}<a href="{{ book.companion_repo }}" target="_blank" rel="noopener">companion repo →</a>{% endif %}
        {% if book.whitepaper %}<a href="{{ book.whitepaper }}">C-DAD white paper →</a>{% endif %}
      </div>
    </div>
  </div>
</div>
{% endfor %}

<section style="margin-top:3rem;padding-top:2rem;border-top:1px solid var(--border);">
  <p style="font-family:var(--mono);font-size:0.72rem;color:var(--mid);margin-bottom:1rem;letter-spacing:0.04em;">THE FRAMEWORKS BEHIND THE BOOKS</p>
  <div style="display:flex;gap:1.5rem;flex-wrap:wrap;">
    <a href="/uma/" style="font-family:var(--mono);font-size:0.78rem;color:var(--fg);border:1px solid var(--border);padding:0.6rem 1.2rem;text-decoration:none;transition:opacity 0.15s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">Universal Microservices Architecture →</a>
    <a href="/c-dad/" style="font-family:var(--mono);font-size:0.78rem;color:var(--fg);border:1px solid var(--border);padding:0.6rem 1.2rem;text-decoration:none;transition:opacity 0.15s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">Contract-Driven AI Development →</a>
  </div>
</section>

    </div>
  </main>

  <aside class="section-toc-aside" aria-label="On this page">
    {% if toc %}
    <span class="section-toc-label">On this page</span>
    <ul class="section-toc-links">
      {% for item in toc %}<li><a href="#{{ item.id }}">{{ item.label }}</a></li>{% endfor %}
    </ul>
    {% endif %}
  </aside>
</div>
