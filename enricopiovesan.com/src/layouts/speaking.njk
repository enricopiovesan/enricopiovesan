---
layout: base.njk
---
{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enricopiovesan.com/" },
        { "@type": "ListItem", "position": 2, "name": "Speaking", "item": "https://enricopiovesan.com/speaking/" }
      ]
    },
    {
      "@type": "PresentationDigitalDocument",
      "name": "Write Once, Run Where It Makes Sense",
      "description": "The architecture of portable business logic with WebAssembly and Universal Microservices Architecture.",
      "author": { "@id": "https://enricopiovesan.com/#person" },
      "about": ["WebAssembly", "Software Architecture", "Platform Engineering"],
      "inLanguage": "en"
    },
    {
      "@type": "PresentationDigitalDocument",
      "name": "Contract-Driven AI Development",
      "description": "How verifiable contracts, automated reasoning, and hybrid governance change how we build AI-assisted systems.",
      "author": { "@id": "https://enricopiovesan.com/#person" },
      "about": ["AI Engineering", "Contract-Driven Development"],
      "inLanguage": "en"
    },
    {
      "@type": "PresentationDigitalDocument",
      "name": "The Day After: Restructuring Software for the Age of AI Agents",
      "description": "Practical patterns for making software organizations legible to AI agents without throwing everything away.",
      "author": { "@id": "https://enricopiovesan.com/#person" },
      "about": ["AI Agents", "Engineering Leadership"],
      "inLanguage": "en"
    }
  ]
}
</script>
{% endblock %}
<section class="hero">
  <p class="hero-label">Speaking</p>
  <h1>{{ intro }}</h1>
</section>

<section class="talks-section">
  <p class="section-label">Current Topics</p>
  {% for talk in talks %}
  <div class="talk">
    <div class="talk-meta">
      <p class="talk-track">{{ talk.track }}</p>
    </div>
    <div class="talk-content">
      <h2>{{ talk.title }}</h2>
      <p>{{ talk.description }}</p>
      {% if talk.based_on %}
      <p class="talk-proof">Based on: <a href="{{ talk.based_on_url }}" target="_blank" rel="noopener">{{ talk.based_on }}</a></p>
      {% endif %}
    </div>
  </div>
  {% endfor %}
</section>

<section class="bio-section">
  <p class="section-label">Speaker Bio</p>
  <div class="bio-text">
    <img src="/src/assets/img/enrico-piovesan.jpg" alt="Enrico Piovesan" class="headshot" width="120" height="120" loading="lazy" />
    <p>{{ bio }}</p>
  </div>
</section>

<section class="availability-section">
  <p>{{ availability }} <a href="{{ contact_url }}" target="_blank" rel="noopener">Contact via LinkedIn →</a></p>
</section>
