---
layout: base.njk
---
{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://enricopiovesan.com/speaking/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enricopiovesan.com/" },
        { "@type": "ListItem", "position": 2, "name": "Speaking", "item": "https://enricopiovesan.com/speaking/" }
      ]
    }
  ]
}
</script>
{% endblock %}

{% set nav = sectionNavs[sectionGroup] %}
<div class="section-shell">

  <aside class="section-nav-aside" aria-label="{{ nav.label }} navigation">
    {% if nav.url %}<a class="section-nav-label{% if page.url == nav.url %} active{% endif %}" href="{{ nav.url }}">{{ nav.label }}</a>{% else %}<span class="section-nav-label">{{ nav.label }}</span>{% endif %}
    {% if nav.links %}
    <ul class="section-nav-links">
      {% for link in nav.links %}
      <li><a href="{{ link.href }}"{% if page.url == link.href %} class="active" aria-current="page"{% endif %}>{{ link.label }}</a></li>
      {% endfor %}
    </ul>
    {% endif %}
  </aside>

  <main class="section-main">
    <nav class="section-breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        {% if breadcrumb %}
          {% for crumb in breadcrumb %}
            {% if loop.last %}<li><span aria-current="page">{{ crumb.label }}</span></li>
            {% else %}<li><a href="{{ crumb.href }}">{{ crumb.label }}</a></li>
            {% endif %}
          {% endfor %}
        {% else %}
        <li><span aria-current="page">Speaking</span></li>
        {% endif %}
      </ol>
    </nav>

    <div class="section-body">
      <h1 class="section-h1">Speaking</h1>
      <p>{{ intro }}</p>

      {% for talk in talks %}
      <div class="talk-entry" id="{{ toc[loop.index0].id if toc[loop.index0] else '' }}">
        <span class="talk-entry-track">{{ talk.track }}</span>
        <h2 class="talk-entry-title">{{ talk.title }}</h2>
        {% if talk.description is string %}
        <p>{{ talk.description }}</p>
        {% else %}
          {% for para in talk.description %}
          <p>{{ para }}</p>
          {% endfor %}
        {% endif %}
        {% if talk.based_on %}
        <p class="talk-entry-source">Based on: <a href="{{ talk.based_on_url }}">{{ talk.based_on }}</a></p>
        {% endif %}
      </div>
      {% endfor %}

      <div class="talk-entry" id="bio">
        <h2 class="talk-entry-title">Speaker bio</h2>
        {% if bio is string %}
        <p>{{ bio }}</p>
        {% else %}
          {% for para in bio %}
          <p>{{ para }}</p>
          {% endfor %}
        {% endif %}
      </div>

      <div class="talk-entry" id="contact">
        <h2 class="talk-entry-title">Book a talk</h2>
        <p>{{ availability }}</p>
        <p><a href="{{ contact_url }}" target="_blank" rel="noopener">Connect on LinkedIn →</a></p>
      </div>
    </div>
  </main>

  <aside class="section-toc-aside" aria-label="On this page">
    {% if toc %}
    <span class="section-toc-label">On this page</span>
    <ul class="section-toc-links">
      {% for item in toc %}<li><a href="#{{ item.id }}">{{ item.label }}</a></li>{% endfor %}
    </ul>
    {% endif %}
  </aside>

</div>
